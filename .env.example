# Example environment file — copy to .env and fill in real values.
# NEVER commit .env to source control.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_api_key_here_optional
GEMINI_MODEL=gemini-2.0-flash

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_a_long_random_string

# ── Local Ollama fallback (optional) ─────────────────────────────────────────
# When the Gemini quota is exhausted the classifier automatically falls back to
# a locally running Ollama server.  No API key required.
#
# Setup:
#   1. Install Ollama:  https://ollama.com/download
#   2. Pull a model:    ollama pull llama3.2
#   3. Ollama starts automatically on port 11434 — no extra config needed.
#
# Available models (larger = more accurate, slower):
#   llama3.2          ~2 GB  fast, good quality  ← recommended default
#   mistral           ~4 GB  very good quality
#   gemma2:2b         ~1.6 GB very fast, decent
#   llama3.1:8b       ~5 GB  best quality for local
#
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
